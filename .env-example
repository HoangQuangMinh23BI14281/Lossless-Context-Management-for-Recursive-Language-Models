# Cấu hình kết nối Ollama (Inference Backend)
OLLAMA_BASE_URL=http://localhost:11434
# Mô hình đóng vai trò làm bộ (Lập kế hoạch & Quyết định)
RLM_MODEL=qwen3.5:4b
# Mô hình đóng vai trò làm các worker (Làm việc phụ/song song)
LCM_WORKER_MODEL=qwen3.5:0.8b

# Cấu trúc lưu trữ (Database)
# Dùng SQLite cho quá trình dev ban đầu để dễ test, sau này đổi sang Postgres
DATABASE_URL=sqlite+aiosqlite:///lcm_store.db

# Giới hạn VRAM & Tài nguyên (Để tránh OOM)
MAX_WORKERS=16
MAX_CONCURRENT_LLM_CALLS=4
VRAM_LIMIT_GB=6

# Tùy chọn Log
LOG_LEVEL=DEBUG
